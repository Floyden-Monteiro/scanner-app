<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:scannermaui.ViewModels"
             x:Class="scannermaui.Views.CartPage"
             Title="Cart"
             BackgroundColor="#F5F5F5">


    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>

        </Grid.RowDefinitions>

        <Label Text="Your Cart"
               FontSize="28"
               FontAttributes="Bold"
               TextColor="Black"
               HorizontalOptions="Center"
               Margin="0,0,0,10"/>

        <CollectionView x:Name="CartListView"
                        ItemsSource="{Binding CartItems}"
                        SelectionMode="None"
                        Grid.Row="1"
                        BackgroundColor="Transparent">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="20"
                           Margin="0,10"
                           BackgroundColor="White"
                           CornerRadius="15"
                           HasShadow="True">
                        <Grid ColumnDefinitions="*, Auto"
                              VerticalOptions="Center"
                              Padding="0,5">

                            <StackLayout Grid.Column="0"
                                         Spacing="5">
                                <Label Text="{Binding ProductName}"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="Black"
                                       VerticalOptions="Center"/>

                                <Label Text="{Binding Price, StringFormat='₹{0:N2}'}"
                                       FontSize="16"
                                       TextColor="Gray"
                                       VerticalOptions="Center"/>
                            </StackLayout>

                            <StackLayout Grid.Column="1"
                                         Orientation="Horizontal"
                                         Spacing="10"
                                         VerticalOptions="Center">

                                <Button Text="–"
                                        FontSize="20"
                                        BackgroundColor="#FF6B6B"
                                        TextColor="White"
                                        WidthRequest="45"
                                        HeightRequest="45"
                                        CornerRadius="8"
                                        Command="{Binding Source={x:Reference CartListView}, Path=BindingContext.DecreaseQuantityCommand}"
                                        CommandParameter="{Binding .}">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button"
                                                     Binding="{Binding Quantity}"
                                                     Value="1">
                                            <Setter Property="IsVisible"
                                                    Value="False"/>
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>


                                <ImageButton Source="delete.png"
                                             WidthRequest="45"
                                             HeightRequest="45"
                                             Padding="10"
                                             BackgroundColor="#f2021a"
                                             CornerRadius="8"
                                             Command="{Binding Source={x:Reference CartListView}, Path=BindingContext.DecreaseQuantityCommand}"
                                             CommandParameter="{Binding .}"
                                             IsVisible="False">
                                    <ImageButton.Triggers>
                                        <DataTrigger TargetType="ImageButton"
                                                     Binding="{Binding Quantity}"
                                                     Value="1">
                                            <Setter Property="IsVisible"
                                                    Value="True"/>
                                        </DataTrigger>
                                    </ImageButton.Triggers>
                                </ImageButton>

                                <Label Text="{Binding Quantity}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center"
                                       TextColor="Black"
                                       WidthRequest="30"
                                       HorizontalTextAlignment="Center"/>

                                <Button Text="+"
                                        FontSize="20"
                                        BackgroundColor="#2ED573"
                                        TextColor="White"
                                        WidthRequest="45"
                                        HeightRequest="45"
                                        CornerRadius="8"
                                        Command="{Binding Source={x:Reference CartListView}, Path=BindingContext.IncreaseQuantityCommand}"
                                        CommandParameter="{Binding .}"/>
                            </StackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Frame CornerRadius="15"
               HasShadow="True"
               Padding="20"
               BackgroundColor="#6A11CB"
               Grid.Row="2"
               Margin="0,20,0,10">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackLayout Grid.Column="0"
                             Orientation="Horizontal"
                             Spacing="10">
                    <Image Source="cart_icon.png"
                           WidthRequest="24"
                           HeightRequest="24"/>
                    <Label Text="{Binding TotalQuantity, StringFormat='Items: {0}'}"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="White"
                           VerticalOptions="Center"/>
                </StackLayout>

                <Label Grid.Column="2"
                       Text="{Binding TotalAmount, StringFormat='Total: ₹{0:N2}'}"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="White"
                       VerticalOptions="Center"/>
            </Grid>
        </Frame>



        <StackLayout Grid.Row="3"
             Orientation="Horizontal" 
             Spacing="10" 
             Margin="0,0,0,10"
             HorizontalOptions="Fill">

            <Button Text="Print Invoice"
            FontSize="16"
            TextColor="White"
            BackgroundColor="#4361EE"
            CornerRadius="8"
            HeightRequest="50"
            HorizontalOptions="FillAndExpand"
            Command="{Binding PrintInvoiceCommand}">
                <Button.Shadow>
                    <Shadow Brush="#4361EE"
                    Offset="0,2"
                    Radius="4"
                    Opacity="0.5"/>
                </Button.Shadow>
            </Button>

            <Button Text="Share Invoice"
            FontSize="16"
            TextColor="White"
            BackgroundColor="#6A11CB"
            CornerRadius="8"
            HeightRequest="50"
            HorizontalOptions="FillAndExpand"
            Command="{Binding ShareInvoiceCommand}">
                <Button.Shadow>
                    <Shadow Brush="#6A11CB"
                    Offset="0,2"
                    Radius="4"
                    Opacity="0.5"/>
                </Button.Shadow>
            </Button>
        </StackLayout>
    </Grid>
</ContentPage>
